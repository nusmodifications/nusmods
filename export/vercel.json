{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "timeout --kill-after=30s 5m pnpm build",
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "/404.html"
    }
  ],
  "functions": {
    "api/export/image.ts": {
      "maxDuration": 15
    },
    "api/export/pdf.ts": {
      "maxDuration": 15
    },
    "api/export/beta/image.ts": {
      "maxDuration": 15
    },
    "api/export/beta/pdf.ts": {
      "maxDuration": 15
    }
  },
  "ignoreCommand": "bash ../vercel_ignore_build.sh"
}
