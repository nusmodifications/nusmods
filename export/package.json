{
  "name": "nusmods-export",
  "version": "0.0.1",
  "private": true,
  "description": "Server-side timetable rendering for NUSMods export service",
  "license": "MIT",
  "author": "NUSModifications",
  "main": "build/src/index.js",
  "scripts": {
    "start": "pm2 start ecosystem.config.js",
    "build": "tsc",
    "nodemon": "nodemon --no-update-notifier -r dotenv/config ./build/src/index.js",
    "watch": "tsc --watch",
    "dev": "run-p nodemon watch",
    "devtools": "cross-env DEVTOOLS=1 pnpm run dev",
    "deploy": "rsync -avu --delete-after . ../../nusmods-export && pm2 restart ecosystem.config.js",
    "format": "oxfmt --no-error-on-unmatched-pattern --write \"src/**/*.{js,ts}\" \"scripts/**/*.{js,ts}\" package.json ecosystem.config.js",
    "format:check": "oxfmt --no-error-on-unmatched-pattern --check \"src/**/*.{js,ts}\" \"scripts/**/*.{js,ts}\" package.json ecosystem.config.js"
  },
  "dependencies": {
    "@sentry/node": "5.30.0",
    "@sparticuz/chromium": "^123.0.0",
    "axios": "0.30.0",
    "bunyan": "1.8.15",
    "fs-extra": "9.1.0",
    "http-graceful-shutdown": "2.4.0",
    "joi": "^17.12.3",
    "koa": "2.16.3",
    "koa-router": "10.1.1",
    "koa-views": "6.3.1",
    "lodash": "4.17.21",
    "nodemon": "2.0.22",
    "pug": "3.0.3",
    "puppeteer-core": "22.15.0"
  },
  "devDependencies": {
    "@types/fs-extra": "9.0.13",
    "@types/koa": "2.15.0",
    "@types/koa-router": "7.4.8",
    "@types/koa-views": "2.0.4",
    "@types/lodash": "4.17.14",
    "@types/node": "22.13.5",
    "@types/pug": "2.0.10",
    "@vercel/node": "1.15.4",
    "cross-env": "7.0.3",
    "dotenv": "8.6.0",
    "npm-run-all": "4.1.5",
    "oxfmt": "0.36.0",
    "typescript": "5.9.3"
  }
}
