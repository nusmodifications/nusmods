{
  "name": "nusmods-export",
  "version": "0.0.1",
  "private": true,
  "description": "Server-side timetable rendering for NUSMods export service",
  "license": "MIT",
  "author": "NUSModifications",
  "main": "build/src/index.js",
  "scripts": {
    "start": "node -r dotenv/config ./build/src/index.js",
    "build": "tsc",
    "nodemon": "nodemon --no-update-notifier -r dotenv/config ./build/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsc --watch",
    "dev": "run-p nodemon watch",
    "check": "run-s lint typecheck",
    "devtools": "cross-env DEVTOOLS=1 pnpm dev",
    "lint": "oxlint -c oxlint.config.mjs src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/node": "5.30.0",
    "@sparticuz/chromium": "^143.0.4",
    "axios": "0.30.0",
    "bunyan": "1.8.15",
    "fs-extra": "9.1.0",
    "http-graceful-shutdown": "2.4.0",
    "joi": "^17.12.3",
    "koa": "2.16.4",
    "koa-router": "10.1.1",
    "koa-static": "^5.0.0",
    "koa-views": "6.3.1",
    "lodash": "4.18.1",
    "nodemon": "2.0.22",
    "pdfkit": "^0.17.2",
    "pug": "3.0.3",
    "puppeteer-core": "^24.38.0",
    "react": "18.3.1",
    "satori": "^0.25.0"
  },
  "devDependencies": {
    "@nkzw/eslint-plugin": "catalog:",
    "@nkzw/oxlint-config": "catalog:",
    "@types/fs-extra": "9.0.13",
    "@types/koa": "2.15.2",
    "@types/koa-router": "7.4.9",
    "@types/koa-static": "^4.0.4",
    "@types/koa-views": "2.0.4",
    "@types/lodash": "4.17.24",
    "@types/node": "catalog:",
    "@types/pdfkit": "^0.17.5",
    "@types/pug": "2.0.10",
    "@types/react": "18.3.18",
    "@vercel/node": "1.15.4",
    "cross-env": "catalog:",
    "dotenv": "8.6.0",
    "eslint-plugin-no-only-tests": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "npm-run-all": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
