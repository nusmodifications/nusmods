{
  "name": "nusmoderator",
  "version": "4.0.0",
  "description": "A lightweight library with helpful functions for NUS-related matters",
  "keywords": [
    "NUS",
    "NUSMods",
    "academic",
    "moderation",
    "moderator",
    "modifications",
    "semester",
    "week",
    "year"
  ],
  "homepage": "https://github.com/nusmodifications/nusmods/tree/master/packages/nusmoderator",
  "bugs": {
    "email": "mods@nusmods.com"
  },
  "license": "MIT",
  "author": "NUSModifications",
  "repository": {
    "type": "git",
    "url": "https://github.com/nusmodifications/nusmods.git"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "jsnext:main": "dist/index.es.js",
  "scripts": {
    "clean": "rimraf dist coverage",
    "lint": "documentation lint src && oxlint -c oxlint.config.mjs src",
    "typecheck": "tsc --noEmit",
    "docs": "documentation readme src --section=API",
    "build": "microbundle",
    "test": "vitest run --coverage",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run test && npm run build && npm run docs --kill --print"
  },
  "dependencies": {
    "date-fns": "2.30.0"
  },
  "devDependencies": {
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/oxlint-config": "^1.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "documentation": "14.0.3",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "microbundle": "0.15.1",
    "oxlint": "^1.51.0",
    "rimraf": "3.0.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "npmName": "nusmoderator"
}
