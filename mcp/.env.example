# Academic year to serve by default, in "YYYY/YYYY" form. Defaults to the
# current NUSMods academic year if unset.
NUSMODS_ACAD_YEAR=2026/2027

# Base URL for the public NUSMods v2 JSON API.
NUSMODS_API_BASE_URL=https://api.nusmods.com

# Base URL for the public NUSMods ElasticSearch cluster that powers search.
NUSMODS_ES_BASE_URL=https://nusmods-search.es.ap-southeast-1.aws.found.io:9243

# Local dev server port (used by `pnpm dev`).
PORT=3000
