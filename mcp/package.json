{
  "name": "nusmods-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Model Context Protocol server for NUSMods module data (mcp.nusmods.com/mcp)",
  "license": "MIT",
  "author": "NUSModifications",
  "type": "module",
  "main": "build/src/dev.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/dev.ts",
    "start": "node build/src/dev.js",
    "lint": "oxlint -c oxlint.config.mjs src api",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "run-s lint typecheck test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nkzw/eslint-plugin": "catalog:",
    "@nkzw/oxlint-config": "catalog:",
    "@types/node": "catalog:",
    "@vercel/node": "^5.8.22",
    "eslint-plugin-no-only-tests": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "npm-run-all": "catalog:",
    "oxlint": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
