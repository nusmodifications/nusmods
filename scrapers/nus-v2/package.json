{
  "name": "nus-v2",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "repository": "https://github.com/nusmodifications/nusmods",
  "main": "src/index.ts",
  "scripts": {
    "scrape": "node build/index.js",
    "dev": "pnpm build && node build/index.js",
    "docs": "cp swagger.yaml docs/* data/",
    "bunyan": "bunyan -L -o short --color",
    "build": "tsc -p tsconfig.prod.json",
    "lint": "oxlint -c oxlint.config.mjs src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "test:watch": "vitest",
    "antlr4ts": "antlr4ts -no-listener -visitor src/services/requisite-tree/antlr4/NusMods.g4 -o src/services/requisite-tree/antlr4/"
  },
  "dependencies": {
    "@elastic/elasticsearch": "7.17.14",
    "@sentry/node": "5.30.0",
    "antlr4ts": "^0.5.0-alpha.4",
    "axios": "0.30.0",
    "bunyan": "1.8.15",
    "date-fns": "2.30.0",
    "deep-diff": "1.0.2",
    "fs-extra": "9.1.0",
    "he": "1.2.0",
    "joi": "17.13.3",
    "lodash": "4.17.23",
    "nusmoderator": "3.0.0",
    "oboe": "2.1.7",
    "promise-queue": "2.2.5",
    "ramda": "0.30.1",
    "romanify": "1.0.0",
    "yargs": "16.2.0"
  },
  "devDependencies": {
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/oxlint-config": "^1.0.1",
    "@types/bunyan": "1.8.11",
    "@types/deep-diff": "1.0.5",
    "@types/fs-extra": "9.0.13",
    "@types/he": "1.2.3",
    "@types/lodash": "4.17.14",
    "@types/mock-fs": "4.13.4",
    "@types/node": "22.13.5",
    "@types/oboe": "2.1.4",
    "@types/promise-queue": "2.2.3",
    "@types/ramda": "0.30.2",
    "@types/yargs": "17.0.33",
    "@vitest/coverage-v8": "^4.0.18",
    "antlr4ts-cli": "^0.5.0-alpha.4",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "http-status": "1.8.1",
    "mock-fs": "5.4.1",
    "oxlint": "^1.51.0",
    "swagger-ui-dist": "4.19.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
