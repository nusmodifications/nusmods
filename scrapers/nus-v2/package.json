{
  "name": "nus-v2",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "repository": "https://github.com/nusmodifications/nusmods",
  "main": "src/index.ts",
  "scripts": {
    "scrape": "node build/index.js",
    "dev": "pnpm build && node build/index.js",
    "docs": "cp swagger.yaml docs/* data/",
    "bunyan": "bunyan -L -o short --color",
    "build": "tsc -p tsconfig.prod.json",
    "lint": "oxlint -c oxlint.config.mjs src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "run-s lint typecheck test",
    "antlr4ts": "antlr4ts -no-listener -visitor src/services/requisite-tree/antlr4/NusMods.g4 -o src/services/requisite-tree/antlr4/"
  },
  "dependencies": {
    "@elastic/elasticsearch": "7.17.14",
    "@sentry/node": "5.30.0",
    "antlr4ts": "^0.5.0-alpha.4",
    "axios": "1.15.0",
    "bunyan": "1.8.15",
    "date-fns": "2.30.0",
    "deep-diff": "1.0.2",
    "fs-extra": "9.1.0",
    "he": "1.2.0",
    "joi": "17.13.3",
    "lodash": "4.18.1",
    "nusmoderator": "3.0.0",
    "oboe": "2.1.7",
    "promise-queue": "2.2.5",
    "ramda": "0.30.1",
    "romanify": "1.0.0",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@nkzw/eslint-plugin": "catalog:",
    "@nkzw/oxlint-config": "catalog:",
    "@types/bunyan": "1.8.11",
    "@types/deep-diff": "1.0.5",
    "@types/fs-extra": "9.0.13",
    "@types/he": "1.2.3",
    "@types/lodash": "4.17.14",
    "@types/mock-fs": "4.13.4",
    "@types/node": "catalog:",
    "@types/oboe": "2.1.4",
    "@types/promise-queue": "2.2.3",
    "@types/ramda": "0.30.2",
    "@types/yargs": "17",
    "@vitest/coverage-v8": "catalog:",
    "antlr4ts-cli": "^0.5.0-alpha.4",
    "eslint-plugin-no-only-tests": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "http-status": "1.8.1",
    "mock-fs": "5.4.1",
    "oxlint": "catalog:",
    "swagger-ui-dist": "4.19.1",
    "ts-node": "10.9.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
