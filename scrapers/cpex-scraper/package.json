{
  "name": "nusmods-cpex-scraper",
  "version": "1.0.0",
  "description": "NUSMods scraper for NUS Course Planning Exercise (CPEx)",
  "license": "MIT",
  "author": "Christopher Goh <chris@nusmods.com>",
  "repository": "https://github.com/nusmodifications/nusmods",
  "main": "src/index.ts",
  "scripts": {
    "scrape": "node build/src/index.js",
    "dev": "yarn build && node build/src/index.js",
    "build": "tsc",
    "lint": "tsc && yarn lint:code && yarn format:check",
    "lint:code": "eslint --ext .js,.ts src",
    "format": "oxfmt --no-error-on-unmatched-pattern --write \"src/**/*.{js,ts}\" package.json",
    "format:check": "oxfmt --no-error-on-unmatched-pattern --check \"src/**/*.{js,ts}\" package.json"
  },
  "dependencies": {
    "axios": "^1.3.4"
  },
  "devDependencies": {
    "@types/node": "22.13.5",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "eslint": "^8.35.0",
    "oxfmt": "0.36.0",
    "typescript": "5.9.3"
  }
}
